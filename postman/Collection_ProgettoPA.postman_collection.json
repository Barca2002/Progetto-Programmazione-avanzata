    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Questo script viene eseguito dopo la response e setta la variabile d'ambiente con il valore del parametro \"token\" del body (preso e trasofrmato in json da appunto .json()) della response. Se l'utente è admin, allora il token verrà salvato nella var. di ambiente per admin, altrimenti in quella per gli utenti normali\r",
                  "// Prima si controlla che lo status della risposta è 200, cioè è andata a buon fine.\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "// Poi salviamo il token nella variabile d'ambiente.\r",
                  "pm.test(\"Salvataggio del token nelle variabili d'ambiente\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    // Controlliamo che il parametro 'token' esista nella risposta\r",
                  "    pm.expect(jsonData.data).to.have.property('token');\r",
                  "    const jwtToken = jsonData.data.token;\r",
                  "    // Controlliamo che il token non sia vuoto o nullo\r",
                  "    pm.expect(jwtToken).to.not.be.null;\r",
                  "    pm.expect(jwtToken).to.not.be.undefined;\r",
                  "    // Splittiamo il token per prendere il payload e controllare il ruolo.\r",
                  "    let [jwtHeader, jwtPayload, jwtSignature] = jwtToken.split('.');\r",
                  "    // Si decodifica da Base64 e poi si parsa in JSON per accedere al campo.\r",
                  "    let jwtPayloadDecoded = JSON.parse(atob(jwtPayload));\r",
                  "    // Controllo del ruolo dell'utente.\r",
                  "    if (jwtPayloadDecoded.is_admin == true) {\r",
                  "        pm.environment.set(\"JWT_TOKEN_ADMIN\", pm.response.json().data.token);\r",
                  "    } else {\r",
                  "        pm.environment.set(\"JWT_TOKEN_USER\", pm.response.json().data.token);\r",
                  "    }\r",
                  "\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
