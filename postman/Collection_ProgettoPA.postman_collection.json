  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "LoginUser",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Questo script viene eseguito dopo la response e setta la variabile d'ambiente JWT_TOKEN con il valore del parametro \"token\" del body (preso e trasofrmato in json da appunto .json()) della response.\r",
                  "// Prima si controlla che lo status della risposta è 200, cioè è andata a buon fine.\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "// Poi salviamo il token nella variabile d'ambiente.\r",
                  "pm.test(\"Salvataggio del token nelle variabili d'ambiente\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    // Controlliamo che il parametro 'token' esista nella risposta\r",
                  "    pm.expect(jsonData.data).to.have.property('token');\r",
                  "\r",
                  "    // Controlliamo che il token non sia vuoto o nullo\r",
                  "    pm.expect(jsonData.data.token).to.not.be.null;\r",
                  "    pm.expect(jsonData.data.token).to.not.be.undefined;\r",
                  "    \r",
                  "    pm.environment.set(\"JWT_TOKEN_USER\", pm.response.json().data.token);\r",
                  "});\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer"
            },
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{API_KEY}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"email\": \"admin@mail.com\",\r\n    \"password\": \"Admin1\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://{{HOST}}:{{PORT}}/auth/login",
              "protocol": "http",
              "host": [
                "{{HOST}}"
              ],
              "port": "{{PORT}}",
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
