{
  // Configurazione del compilatore tsc
  "compilerOptions": {
    // Configurazione dell'ambiente
    "module": "nodenext",
    "target": "es2022",
    "types": ["jest", "node"],

    // Layout delle directory root e output per il compilatore tsc.
    "rootDir": "./backend/src",
    "outDir": "./ts-build",

    // Configurazione type checking e controlli rigorosi
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUnusedLocals": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
  },
  "include": ["backend/src/**/*.ts"],
  "exclude": ["node_modules", "ts-build"]
}